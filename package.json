{
  "name": "vscode-debugger-mcp",
  "displayName": "VsCode-Debugger-MCP",
  "description": "An MCP server combined with a VSCode plugin provides AI with the capability for breakpoint debugging within VSCode.",
  "version": "1.2.0",
  "publisher": "Albro3459",
  "repository": {
    "type": "git",
    "url": "https://github.com/Albro3459/VsCodeDebugger-MCP.git"
  },
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "DebugMcpManager.showServerMenu",
        "title": "Debug MCP: Show Server Actions"
      },
      {
        "command": "DebugMcpManager.copyMcpConfig",
        "title": "Debug MCP: Copy MCP Server Config"
      }
    ],
    "configuration": {
      "title": "VSCode Debugger MCP",
      "properties": {
        "vscode-debugger-mcp.server.port": {
          "type": "number",
          "default": 6009,
          "minimum": 1025,
          "maximum": 65535,
          "scope": "window",
          "markdownDescription": "Port used by the bundled MCP server."
        },
        "vscode-debugger-mcp.server.autoStart": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "markdownDescription": "Automatically start the MCP server when the extension activates."
        }
      }
    }
  },
  "dependencies": {
    "eventsource": "^4.1.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.8",
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3"
  }
}
